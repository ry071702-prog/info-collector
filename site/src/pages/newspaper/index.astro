---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { allArticles } from "../../lib/articles";
import { formatJapaneseDate } from "../../lib/japaneseDate";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 直近30日のうち記事のある日付を新しい順に
const articles = allArticles();
const dateMap = new Map<string, number>();
for (const a of articles) {
  const ts = new Date(a.timestamp);
  if (Number.isNaN(ts.getTime())) continue;
  const jst = new Date(ts.getTime() + 9 * 60 * 60 * 1000);
  const d = jst.toISOString().slice(0, 10);
  dateMap.set(d, (dateMap.get(d) ?? 0) + 1);
}
const dates = [...dateMap.entries()]
  .sort((a, b) => b[0].localeCompare(a[0]))
  .slice(0, 30);
---

<BaseLayout title="新聞アーカイブ">
  <section class="mb-6">
    <h1 class="font-serif-jp text-3xl font-black tracking-normal text-stone-950 sm:text-4xl dark:text-white">日刊 情報収集 — 新聞アーカイブ</h1>
    <p class="mt-2 text-sm text-stone-600 dark:text-stone-400">
      毎日その日のニュースを 1 ページの新聞風レイアウトでまとめます。見出しから元記事へ遷移できます。
    </p>
  </section>

  {dates.length === 0 ? (
    <p class="text-sm text-stone-500 dark:text-stone-400">まだ新聞が発行されていません。</p>
  ) : (
    <ul class="divide-y divide-stone-300 dark:divide-stone-700">
      {dates.map(([date, count]) => (
        <li class="py-3">
          <a href={`${base}/newspaper/${date}/`} class="group flex items-center justify-between gap-4">
            <div>
              <h2 class="font-serif-jp text-lg font-bold text-stone-950 group-hover:underline dark:text-white">
                {formatJapaneseDate(`${date}T12:00:00+09:00`)}
              </h2>
              <p class="text-xs text-stone-500 dark:text-stone-400">{count} 件の記事を収録</p>
            </div>
            <span class="font-serif-jp text-xs text-stone-500 group-hover:text-stone-900 dark:text-stone-400 dark:group-hover:text-white">読む →</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
