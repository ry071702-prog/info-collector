---
import ArticleControls from "../../components/ArticleControls.astro";
import NewsCard from "../../components/NewsCard.astro";
import NewsCardSkeleton from "../../components/NewsCardSkeleton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articlesByGenre } from "../../lib/articles";

const articles = articlesByGenre("anime");
---

<BaseLayout title="アニメ">
  <section class="mb-6">
    <h1 class="section-title text-3xl">アニメ</h1>
    <p class="mt-2 text-sm section-copy">直近30日のアニメニュース全件。</p>
  </section>
  <ArticleControls showRange />
  {
    articles.length > 0 ? (
      <>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" data-article-skeletons>
          <NewsCardSkeleton count={8} />
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" data-article-list>
          {articles.map((article) => <NewsCard article={article} />)}
        </div>
      </>
    ) : (
      <p class="empty-state p-6 text-sm">
        表示できるアニメニュースはまだありません。
      </p>
    )
  }
</BaseLayout>
