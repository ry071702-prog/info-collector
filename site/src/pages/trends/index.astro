---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { genreColors, genreLabels, genres, loadSiteData, type Genre } from "../../lib/articles";
import { buildTrendsData } from "../../lib/trends";

const siteData = loadSiteData();
const trends = buildTrendsData(siteData.articles, siteData.generated_at);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const feedPath = `${base}/feed/`;

const summaryCards = [
  { label: "総記事数", value: `${trends.summary.totalArticles}`, note: "過去30日" },
  { label: "今日の新着数", value: `${trends.summary.todayArticles}`, note: "JST基準" },
  { label: "アクティブな source 数", value: `${trends.summary.activeSources}`, note: "1件以上配信" },
  {
    label: "平均重要度",
    value: trends.summary.averageImportance === null ? "-" : trends.summary.averageImportance.toFixed(1),
    note: trends.summary.averageImportanceLabel,
  },
];

const chartWidth = 720;
const chartHeight = 280;
const chartPadding = { top: 18, right: 12, bottom: 34, left: 36 };
const plotWidth = chartWidth - chartPadding.left - chartPadding.right;
const plotHeight = chartHeight - chartPadding.top - chartPadding.bottom;
const maxDaily = Math.max(1, ...trends.dailyCounts.map((day) => day.total));
const barSlot = plotWidth / trends.dailyCounts.length;
const barWidth = Math.max(5, barSlot * 0.68);
const yTicks = Array.from(new Set([0, Math.ceil(maxDaily / 2), maxDaily]));

const donutRadius = 58;
let donutOffset = 0;
const donutSegments = trends.genreShares.map((share) => {
  const segment = { ...share, offset: donutOffset };
  donutOffset += share.percentage;
  return segment;
});

const totalLabel = `全 ${trends.summary.totalArticles} 件`;
const heatBackground = (intensity: number) => {
  if (intensity <= 0) return "background-color: rgba(148, 163, 184, 0.16);";
  const alpha = 0.18 + intensity * 0.62;
  return `background-color: rgba(37, 99, 235, ${alpha.toFixed(2)});`;
};

function stackedSegments(day: (typeof trends.dailyCounts)[number], index: number) {
  const x = chartPadding.left + index * barSlot + (barSlot - barWidth) / 2;
  let usedHeight = 0;
  return genres.map((genre) => {
    const count = day.genres[genre] ?? 0;
    const height = (count / maxDaily) * plotHeight;
    usedHeight += height;
    return {
      genre,
      count,
      x,
      y: chartPadding.top + plotHeight - usedHeight,
      width: barWidth,
      height,
      color: genreColors[genre],
    };
  });
}
---

<BaseLayout title="トレンド" description="直近30日の記事数、ジャンル比率、source別配信数、活発な時間帯を可視化します。">
  <section class="mb-8">
    <h1 class="section-title text-3xl sm:text-4xl">トレンド</h1>
    <p class="mt-3 max-w-3xl text-sm leading-6 section-copy">
      直近30日の収集データを、件数推移・ジャンル構成・source別の動きで俯瞰します。
    </p>
  </section>

  <section class="mb-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4" aria-label="サマリー">
    {
      summaryCards.map((card) => (
        <div class="glass-panel p-5">
          <p class="text-sm font-bold section-kicker">{card.label}</p>
          <p class="mt-3 text-3xl font-black tracking-normal text-[var(--text-primary)]">{card.value}</p>
          <p class="mt-2 text-xs section-kicker">{card.note}</p>
        </div>
      ))
    }
  </section>

  <div class="grid gap-8 xl:grid-cols-[minmax(0,1.7fr)_minmax(320px,0.8fr)]">
    <section class="glass-panel p-5">
      <div class="mb-5">
        <h2 class="section-title text-xl">日次推移</h2>
        <p class="mt-1 text-sm section-copy">過去30日の日別記事数をジャンルごとに積み上げ表示します。</p>
      </div>
      <div class="overflow-x-auto">
        <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="h-auto min-w-[640px] max-w-full" role="img" aria-label="過去30日の日別記事数">
          <line
            x1={chartPadding.left}
            y1={chartPadding.top + plotHeight}
            x2={chartPadding.left + plotWidth}
            y2={chartPadding.top + plotHeight}
            class="stroke-slate-300/80 dark:stroke-white/20"
          />
          {
            yTicks.map((tick) => {
              const y = chartPadding.top + plotHeight - (tick / maxDaily) * plotHeight;
              return (
                <g>
                  <line x1={chartPadding.left} y1={y} x2={chartPadding.left + plotWidth} y2={y} class="stroke-slate-200/70 dark:stroke-white/10" />
                  <text x={chartPadding.left - 8} y={y + 4} text-anchor="end" class="fill-slate-500 text-[10px] dark:fill-slate-300">
                    {tick}
                  </text>
                </g>
              );
            })
          }
          {
            trends.dailyCounts.map((day, index) => (
              <g>
                <title>{`${day.date}: ${day.total}件`}</title>
                {stackedSegments(day, index).map((segment) =>
                  segment.count > 0 ? (
                    <rect
                      x={segment.x}
                      y={segment.y}
                      width={segment.width}
                      height={Math.max(1, segment.height)}
                      fill={segment.color}
                      rx="2"
                    />
                  ) : null,
                )}
                {index % 5 === 0 && (
                  <text
                    x={chartPadding.left + index * barSlot + barSlot / 2}
                    y={chartHeight - 10}
                    text-anchor="middle"
                    class="fill-slate-500 text-[10px] dark:fill-slate-300"
                  >
                    {day.label}
                  </text>
                )}
              </g>
            ))
          }
        </svg>
      </div>
      <div class="mt-4 flex flex-wrap gap-3">
        {
          genres.map((genre) => (
            <span class="inline-flex items-center gap-2 text-xs section-kicker">
              <span class="h-2.5 w-2.5 rounded-sm" style={`background-color: ${genreColors[genre]}`}></span>
              {genreLabels[genre]}
            </span>
          ))
        }
      </div>
    </section>

    <section class="glass-panel p-5">
      <div class="mb-5">
        <h2 class="section-title text-xl">ジャンル別比率</h2>
        <p class="mt-1 text-sm section-copy">過去30日の全記事をジャンル別の割合で確認します。</p>
      </div>
      <div class="flex flex-col items-center gap-5">
        <svg viewBox="0 0 160 160" class="h-48 w-48" role="img" aria-label="ジャンル別比率">
          <circle cx="80" cy="80" r={donutRadius} fill="none" class="stroke-slate-200/80 dark:stroke-white/10" stroke-width="22" />
          {
            donutSegments.map((segment) =>
              segment.count > 0 ? (
                <circle
                  cx="80"
                  cy="80"
                  r={donutRadius}
                  fill="none"
                  stroke={segment.color}
                  stroke-width="22"
                  pathLength="100"
                  stroke-dasharray={`${segment.percentage} ${100 - segment.percentage}`}
                  stroke-dashoffset={-segment.offset}
                  stroke-linecap="butt"
                  transform="rotate(-90 80 80)"
                >
                  <title>{`${segment.label}: ${segment.count}件`}</title>
                </circle>
              ) : null,
            )
          }
          <text x="80" y="76" text-anchor="middle" class="fill-slate-500 text-[11px] font-medium dark:fill-slate-300">全体</text>
          <text x="80" y="96" text-anchor="middle" class="fill-slate-950 text-[16px] font-bold dark:fill-white">{totalLabel}</text>
        </svg>
        <div class="w-full space-y-2">
          {
            trends.genreShares.map((share) => (
              <div class="flex items-center justify-between gap-4 text-sm">
                <span class="inline-flex min-w-0 items-center gap-2 section-copy">
                  <span class="h-2.5 w-2.5 shrink-0 rounded-sm" style={`background-color: ${share.color}`}></span>
                  <span class="truncate">{share.label}</span>
                </span>
                <span class="shrink-0 font-bold text-[var(--text-primary)]">{share.count}件</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>

  <div class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1.25fr)_minmax(320px,0.75fr)]">
    <section class="glass-panel p-5">
      <div class="mb-5">
        <h2 class="section-title text-xl">source 別 Top 10</h2>
        <p class="mt-1 text-sm section-copy">配信数の多い source をランキングし、クリックで最新フィードの source フィルタへ移動します。</p>
      </div>
      {
        trends.topSources.length > 0 ? (
          <ol class="space-y-3">
            {trends.topSources.map((source, index) => (
              <li>
                <a
                  href={`${feedPath}?source=${encodeURIComponent(source.key)}`}
                  class="group block rounded-2xl border border-white/45 bg-white/34 p-3 transition hover:border-cyan-300/60 hover:bg-white/55 dark:border-white/10 dark:bg-white/5 dark:hover:border-cyan-300/35 dark:hover:bg-white/10"
                >
                  <div class="mb-2 flex items-center justify-between gap-3 text-sm">
                    <span class="min-w-0 truncate font-bold section-copy group-hover:text-[var(--text-primary)]">
                      {index + 1}. {source.label} — {source.count}件
                    </span>
                    <span class="shrink-0 text-xs section-kicker">{Math.round(source.percentage)}%</span>
                  </div>
                  <div class="h-2 overflow-hidden rounded-full bg-white/55 dark:bg-white/10">
                    <div class="h-full rounded-full bg-gradient-to-r from-blue-600 to-cyan-400" style={`width: ${source.percentage}%`}></div>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <p class="glass-empty p-6 text-sm">
            集計できる source はまだありません。
          </p>
        )
      }
    </section>

    <section class="glass-panel p-5">
      <div class="mb-5">
        <h2 class="section-title text-xl">直近の活発な時間帯</h2>
        <p class="mt-1 text-sm section-copy">過去7日分を4時間ごとに集計し、濃淡で活動量を示します。</p>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-2">
        {
          trends.activeHours.map((bucket) => (
            <div
              class="rounded-2xl border border-white/45 p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.45)] dark:border-white/10"
              style={heatBackground(bucket.intensity)}
            >
              <p class="text-xs font-bold section-copy">{bucket.label}</p>
              <p class="mt-2 text-2xl font-black text-[var(--text-primary)]">{bucket.count}</p>
              <p class="mt-1 text-xs section-kicker">件</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
