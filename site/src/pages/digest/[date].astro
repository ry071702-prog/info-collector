---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { allArticles, byImportance, loadDigestDocument, loadDigests, type Article } from "../../lib/articles";
import { formatJapaneseDate } from "../../lib/japaneseDate";
import { getPublicationMeta } from "../../lib/issueNumber";

export function getStaticPaths() {
  return loadDigests().map((digest) => ({
    params: { date: digest.slug },
    props: { date: digest.slug },
  }));
}

interface Props {
  date: string;
}

interface DigestSection {
  title: string;
  items: string[];
}

const { date } = Astro.props;
const digest = loadDigestDocument(date);
const publication = getPublicationMeta(date);
const publicationDate = new Date(`${date.slice(0, 10)}T00:00:00+09:00`);
const fullDateLabel = formatJapaneseDate(publicationDate);
const editionLabel = publication.edition === "AM" ? "朝刊" : "夕刊";
const issueLabel = `${editionLabel} 第${publication.issueNumber}号`;
const exportDate = date.slice(0, 10);
const exportFilename = `情報収集_${editionLabel}第${publication.issueNumber}号_${exportDate}.png`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function cleanLine(line: string): string {
  return line
    .replace(/^#+\s*/, "")
    .replace(/^[-*]\s+/, "")
    .replace(/^[\p{Extended_Pictographic}\uFE0F]+\s*/u, "")
    .trim();
}

function stripMarkdown(value: string): string {
  return cleanLine(value)
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1");
}

function extractSections(markdown: string): DigestSection[] {
  const sections: DigestSection[] = [];
  let current: DigestSection | null = null;

  for (const rawLine of markdown.split(/\r?\n/)) {
    const line = rawLine.trim();
    if (/^##+\s+/.test(line)) {
      current = { title: stripMarkdown(line), items: [] };
      sections.push(current);
      continue;
    }
    if (/^[-*]\s+/.test(line)) {
      if (current === null) {
        current = { title: "主要トピック", items: [] };
        sections.push(current);
      }
      current.items.push(stripMarkdown(line));
    }
  }

  return sections.filter((section) => section.title || section.items.length > 0);
}

function extractUrls(markdown: string): string[] {
  return Array.from(markdown.matchAll(/\[[^\]]+\]\((https?:\/\/[^)]+)\)/g), (match) => match[1]);
}

function localImagePath(article: Article | undefined): string | null {
  if (!article?.image_url) {
    return null;
  }
  return article.image_url.startsWith("http") ? article.image_url : `${base}${article.image_url}`;
}

const sections = digest ? extractSections(digest.markdown) : [];
const firstItems = sections.flatMap((section) => section.items).slice(0, 4);
const title = digest?.title ?? `Digest ${date}`;
const subtitle = firstItems[0] ?? "ゲーム、アニメ、Disney 周辺の動きを半日単位で整理。";
const leadParagraphs = firstItems.length > 0
  ? firstItems.slice(0, 3)
  : ["重要度の高い話題を中心に、ソース横断で見えた変化を新聞面として再構成しました。"];
const columnSections = sections.length > 0 ? sections.slice(0, 3) : [{ title: "主要トピック", items: leadParagraphs }];
const digestUrls = digest ? extractUrls(digest.markdown) : [];
const relatedArticles = byImportance(allArticles().filter((article) => digestUrls.includes(article.url)));
const leadArticle = relatedArticles[0];
const leadImage = localImagePath(leadArticle);
const placeholderSvg = `data:image/svg+xml;utf8,${encodeURIComponent(`
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 480">
    <defs>
      <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
        <stop stop-color="#2563eb"/>
        <stop offset="0.52" stop-color="#06b6d4"/>
        <stop offset="1" stop-color="#fbbf24"/>
      </linearGradient>
    </defs>
    <rect width="640" height="480" fill="#edf5ff"/>
    <rect x="72" y="64" width="496" height="352" rx="42" fill="url(#g)" opacity="0.9"/>
    <circle cx="184" cy="152" r="64" fill="white" opacity="0.32"/>
    <path d="M154 280h332M154 326h258" stroke="white" stroke-width="24" stroke-linecap="round" opacity="0.72"/>
    <path d="M154 214h196" stroke="white" stroke-width="34" stroke-linecap="round" opacity="0.9"/>
  </svg>
`)}`;
---

<BaseLayout title={title}>
  {
    digest ? (
      <>
        <div class="mb-4 flex justify-end">
          <button
            type="button"
            class="glass-control px-4 text-sm font-bold"
            data-export-newspaper
            data-export-filename={exportFilename}
          >
            画像として保存
          </button>
        </div>

        <article
          data-newspaper-page
          class="glass-panel grid gap-0 overflow-hidden text-[var(--text-primary)] lg:grid-cols-[minmax(0,1fr)_96px]"
        >
          <aside class="newspaper-sidebar order-first border-b border-[var(--glass-hairline)] bg-white/36 p-4 dark:bg-white/5 lg:order-last lg:border-b-0 lg:border-l">
            <div class="flex flex-wrap items-center justify-between gap-3 text-sm font-bold lg:h-full lg:flex-col lg:justify-start lg:[writing-mode:vertical-rl]">
              <span class="text-2xl font-black tracking-normal">{publication.name}</span>
              <span class="text-xl font-black">{issueLabel}</span>
              <time class="text-sm tracking-normal section-kicker" datetime={exportDate}>{publication.dateLabel}</time>
            </div>
          </aside>

          <div class="p-5 sm:p-8 lg:p-10">
            <div class="mb-6 flex flex-col gap-2 border-b border-[var(--glass-hairline)] pb-3 text-xs font-bold section-kicker sm:flex-row sm:items-center sm:justify-between">
              <span>著者: 自動生成 (Gemini)</span>
              <time class="text-sm" datetime={exportDate}>{fullDateLabel}</time>
            </div>

            <header class="border-b border-[var(--glass-hairline)] pb-6">
              <p class="mb-2 text-sm font-black tracking-normal text-cyan-700 dark:text-cyan-200">{issueLabel}</p>
              <h1 class="text-4xl font-black leading-tight tracking-normal sm:text-5xl lg:text-6xl">{title}</h1>
              <p class="mt-5 text-lg font-bold leading-8 section-copy">{subtitle}</p>
            </header>

            <section class="mt-7 flow-root border-b border-[var(--glass-hairline)] pb-7">
              <figure class="mb-4 overflow-hidden rounded-3xl border border-white/50 bg-white/35 shadow-lg dark:border-white/10 dark:bg-white/5 sm:float-left sm:mb-3 sm:mr-6 sm:w-[42%] lg:w-[38%]">
                <img
                  src={leadImage ?? placeholderSvg}
                  alt=""
                  class="aspect-[4/3] w-full object-cover"
                  loading="eager"
                />
                <figcaption class="border-t border-[var(--glass-hairline)] px-3 py-2 text-xs section-kicker">
                  source: {leadArticle?.category_name ?? leadArticle?.author ?? "情報収集"}
                </figcaption>
              </figure>
              <div class="newspaper-lead space-y-4 text-base leading-8 section-copy">
                {leadParagraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </section>

            <section class="mt-7">
              <h2 class="border-y border-[var(--glass-hairline)] py-3 text-2xl font-black">
                {sections[0]?.title ?? "なぜいま注目なのか"}
              </h2>
              <div class="mt-5 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {columnSections.map((section) => (
                  <section class="rounded-3xl border border-white/45 bg-white/35 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.52)] dark:border-white/10 dark:bg-white/5">
                    <h3 class="mb-3 text-xl font-black leading-snug">
                      （{section.title.replace(/^速報・重要\s*\(S\/A\)$/, "速報・重要")}）
                    </h3>
                    <div class="space-y-3 text-sm leading-7 section-copy">
                      {(section.items.length > 0 ? section.items : leadParagraphs).slice(0, 5).map((item) => (
                        <p>{item}</p>
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </section>
          </div>
        </article>
      </>
    ) : (
      <p class="glass-empty p-6 text-sm">
        指定されたまとめは見つかりません。
      </p>
    )
  }

  <script>
    const button = document.querySelector("[data-export-newspaper]");
    const page = document.querySelector("[data-newspaper-page]");

    const loadImage = (url) =>
      new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = reject;
        image.src = url;
      });

    const nodeToPng = async (node) => {
      const rect = node.getBoundingClientRect();
      const width = Math.ceil(rect.width);
      const height = Math.ceil(rect.height);
      const clone = node.cloneNode(true);
      const style = document.createElement("style");
      style.textContent = Array.from(document.styleSheets)
        .flatMap((sheet) => {
          try {
            return Array.from(sheet.cssRules, (rule) => rule.cssText);
          } catch {
            return [];
          }
        })
        .join("\n");
      clone.prepend(style);
      clone.setAttribute("xmlns", "http://www.w3.org/1999/xhtml");
      clone.style.width = `${width}px`;
      clone.style.minHeight = `${height}px`;
      const html = new XMLSerializer().serializeToString(clone);
      const svg = `
        <svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}">
          <foreignObject width="100%" height="100%">${html}</foreignObject>
        </svg>
      `;
      const url = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
      const image = await loadImage(url);
      const canvas = document.createElement("canvas");
      const scale = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = width * scale;
      canvas.height = height * scale;
      const context = canvas.getContext("2d");
      if (!context) throw new Error("Canvas is not available");
      context.scale(scale, scale);
      context.drawImage(image, 0, 0);
      return canvas.toDataURL("image/png");
    };

    button?.addEventListener("click", async () => {
      if (!(button instanceof HTMLButtonElement) || !(page instanceof HTMLElement)) return;
      const filename = button.dataset.exportFilename || "日刊情報収集.png";
      const originalText = button.textContent;
      button.disabled = true;
      button.textContent = "生成中...";
      try {
        const dataUrl = await nodeToPng(page);
        const link = document.createElement("a");
        link.download = filename;
        link.href = dataUrl;
        link.click();
      } finally {
        button.disabled = false;
        button.textContent = originalText;
      }
    });
  </script>
</BaseLayout>
