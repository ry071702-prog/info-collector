---
import { loadDigestDocument, type Digest } from "../lib/articles";

interface Props {
  digest: Digest;
}

const { digest } = Astro.props;
const document = loadDigestDocument(digest.slug);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// slug 末尾 -AM / -PM で朝夕を区別
const suffix = digest.slug.match(/-(AM|PM)$/i)?.[1]?.toUpperCase() ?? null;
const cycleLabel = suffix === "AM" ? "AM" : suffix === "PM" ? "PM" : "DAILY";
---

<a
  href={`${base}/digest/${digest.slug}/`}
  class="glass-card block p-4"
  style="--card-accent: var(--color-games-start); --card-accent-end: var(--color-games-end); --card-glow: var(--glow-neutral); --card-border-hover: rgba(148, 163, 184, 0.42);"
>
  <p class="section-kicker flex items-center gap-2 text-xs font-semibold">
    <span class="rounded-full border border-white/50 bg-white/55 px-2 py-0.5 text-[10px] font-black text-[var(--text-primary)] dark:border-white/15 dark:bg-white/10">{cycleLabel}</span>
    {digest.label}
  </p>
  <h3 class="news-card-title mt-2 text-lg font-black leading-snug">{document?.title ?? `Digest ${digest.label}`}</h3>
  {
    document?.excerpt && (
      <p class="mt-2 line-clamp-2 text-sm leading-6 section-copy">{document.excerpt}</p>
    )
  }
</a>
