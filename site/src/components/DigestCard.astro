---
import { loadDigestDocument, type Digest } from "../lib/articles";

interface Props {
  digest: Digest;
}

const { digest } = Astro.props;
const document = loadDigestDocument(digest.slug);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// slug 末尾 -AM / -PM で 朝刊 / 夕刊 を区別
const suffix = digest.slug.match(/-(AM|PM)$/i)?.[1]?.toUpperCase() ?? null;
const cycleIcon = suffix === "AM" ? "🌅" : suffix === "PM" ? "🌇" : "📰";
---

<a
  href={`${base}/digest/${digest.slug}/`}
  class="block rounded-sm border border-stone-300 bg-[var(--paper)] p-4 shadow-sm hover:border-stone-500 hover:shadow-md dark:border-stone-700 dark:bg-stone-900 dark:hover:border-stone-500"
>
  <p class="text-xs font-semibold text-stone-500 dark:text-stone-400">
    <span class="mr-1">{cycleIcon}</span>{digest.label}
  </p>
  <h3 class="font-serif-jp mt-2 text-lg font-black leading-snug text-stone-950 dark:text-white">{document?.title ?? `Digest ${digest.label}`}</h3>
  {
    document?.excerpt && (
      <p class="mt-2 line-clamp-2 text-sm leading-6 text-stone-600 dark:text-stone-300">{document.excerpt}</p>
    )
  }
</a>
