---
import { loadDigestDocument, type Digest } from "../lib/articles";

interface Props {
  digest: Digest;
}

const { digest } = Astro.props;
const document = loadDigestDocument(digest.slug);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<a
  href={`${base}/digest/${digest.slug}/`}
  class="block rounded-lg border border-slate-200 bg-white p-4 shadow-sm hover:border-slate-300 hover:shadow-md dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700"
>
  <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">{digest.label}</p>
  <h3 class="mt-2 text-base font-bold text-slate-950 dark:text-white">{document?.title ?? `Digest ${digest.label}`}</h3>
  {
    document?.excerpt && (
      <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{document.excerpt}</p>
    )
  }
</a>
