---
interface Props {
  count?: number;
}

const { count = 8 } = Astro.props;
---

<>
  {
    Array.from({ length: count }).map(() => (
      <div class="surface-card h-full overflow-hidden">
        <div class="skeleton-block aspect-[16/9] animate-pulse"></div>
        <div class="space-y-3 p-4">
          <div class="flex gap-2">
            <div class="skeleton-block h-6 w-10 animate-pulse rounded-full"></div>
            <div class="skeleton-block h-6 w-16 animate-pulse rounded-full"></div>
          </div>
          <div class="skeleton-block h-5 w-4/5 animate-pulse rounded-full"></div>
          <div class="space-y-2">
            <div class="skeleton-block h-4 animate-pulse rounded-full"></div>
            <div class="skeleton-block h-4 w-2/3 animate-pulse rounded-full"></div>
          </div>
          <div class="flex gap-1.5">
            <div class="skeleton-block h-6 w-14 animate-pulse rounded-full"></div>
            <div class="skeleton-block h-6 w-20 animate-pulse rounded-full"></div>
          </div>
          <div class="flex justify-between pt-1">
            <div class="skeleton-block h-4 w-24 animate-pulse rounded-full"></div>
            <div class="skeleton-block h-4 w-14 animate-pulse rounded-full"></div>
          </div>
        </div>
      </div>
    ))
  }
</>
