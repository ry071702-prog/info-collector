---
import LandingIcon from "./LandingIcon.astro";

interface Props {
  title: string;
  body: string;
  icon: string;
}

const { title, body, icon } = Astro.props;
---

<article class="lp-card flex gap-4 p-5 sm:p-6" data-reveal>
  <div class="lp-icon shrink-0">
    <LandingIcon name={icon} />
  </div>
  <div>
    <h3 class="text-lg font-bold text-slate-950">{title}</h3>
    <p class="mt-2 text-sm leading-6 text-slate-600">{body}</p>
  </div>
</article>
