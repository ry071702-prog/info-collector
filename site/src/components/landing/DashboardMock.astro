---
import { genreLabels, type Article } from "../../lib/articles";
import { type SiteStats } from "../../lib/stats";

interface Props {
  stats: SiteStats;
  articles?: Article[];
}

const { stats, articles: sourceArticles = [] } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("ja-JP", {
  timeZone: "Asia/Tokyo",
  month: "2-digit",
  day: "2-digit",
});
const fallbackArticles = [
  { category: "ゲーム", priority: "A", title: "大会アップデートまとめ", summary: "公式発表と配信者の反応を整理。大会環境への影響を短く確認できます。", tags: ["eスポーツ", "大会"], date: "06/05" },
  { category: "アニメ", priority: "S", title: "続編発表の注目ポイント", summary: "放送予定、制作体制、SNS の反応を重要度付きでまとめています。", tags: ["続編", "制作発表"], date: "06/05" },
  { category: "Disney", priority: "B", title: "パーク運営情報の更新", summary: "新施設と混雑に関わる変更点を、来園前に読める粒度へ圧縮します。", tags: ["パーク", "施設"], date: "06/04" },
];
const articles =
  sourceArticles.length > 0
    ? sourceArticles.slice(0, 3).map((article) => ({
        category: genreLabels[article.genre],
        priority: article.final_priority,
        title: article.category_name || article.title_tags[0] || "最新トピック",
        summary: article.summary || "概要はまだありません。",
        tags: [...article.entity_tags, ...article.title_tags].filter(Boolean).slice(0, 2),
        date: dateFormatter.format(new Date(article.timestamp)),
      }))
    : fallbackArticles;
const topTags = stats.topTags.length > 0 ? stats.topTags.slice(0, 5).map((tag) => tag.tag) : ["FPS", "新作", "パーク", "続編", "大会"];
const recentUpdates = stats.topSources.slice(0, 3);
---

<section class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <p class="lp-eyebrow">気になる情報を、AIが整理する。</p>
      <h2 class="lp-title mt-4 text-3xl font-bold sm:text-4xl">“使えそう”が、ひと目で分かる。</h2>
      <p class="lp-copy mt-4 text-base leading-7">
        検索、カテゴリ、重要度、タグを同じ画面で扱えるフィード。読む順番を決めやすいように、必要な文脈を先に見せます。
      </p>
    </div>

    <div class="lp-mock mt-10 grid gap-5 p-4 sm:p-6 lg:grid-cols-[1fr_18rem]" data-reveal>
      <div class="min-w-0">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="soft-card flex min-h-12 flex-1 items-center gap-3 px-4 text-sm font-bold section-kicker">
            <svg class="h-5 w-5 text-[var(--brand-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M11 18a7 7 0 1 0 0-14 7 7 0 0 0 0 14Z" stroke-linecap="round"></path>
              <path d="m16 16 4 4" stroke-linecap="round"></path>
            </svg>
            キーワードで検索
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-[var(--brand-blue)] px-4 py-2 text-xs font-bold text-white">ゲーム</span>
            <span class="status-chip px-4 py-2 text-xs font-bold">アニメ</span>
            <span class="status-chip px-4 py-2 text-xs font-bold">Disney</span>
          </div>
        </div>

        <div class="mt-5 grid gap-4 lg:grid-cols-3">
          {
            articles.map((article) => (
              <article class="lp-mock-card p-4">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="status-chip px-3 py-1 text-xs font-bold">{article.category}</span>
                  <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-black text-orange-700">重要度{article.priority}</span>
                  <time class="ml-auto text-xs font-bold text-[var(--text-muted)]">{article.date}</time>
                </div>
                <h3 class="lp-title mt-3 text-base font-semibold leading-6">{article.title}</h3>
                <p class="lp-copy mt-2 text-sm leading-6">{article.summary}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {article.tags.map((tag) => (
                    <span class="status-chip px-2.5 py-1 text-xs font-bold">#{tag}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="soft-card p-4">
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          <div class="lp-mock-card p-4">
            <p class="text-xs font-bold text-[var(--text-muted)]">今日の新着数</p>
            <p class="lp-title mt-1 text-3xl font-semibold">{stats.todayArticles}</p>
          </div>
          <div class="lp-mock-card p-4">
            <p class="text-xs font-bold text-[var(--text-muted)]">今週の新着数</p>
            <p class="lp-title mt-1 text-3xl font-semibold">{stats.weekArticles}</p>
          </div>
        </div>
        <div class="mt-5">
          <p class="text-xs font-black uppercase text-[var(--text-muted)]">よく使うタグ</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {topTags.map((tag) => (
              <span class="status-chip px-3 py-1.5 text-xs font-bold">#{tag}</span>
            ))}
          </div>
        </div>
        <div class="mt-5">
          <p class="text-xs font-black uppercase text-[var(--text-muted)]">最近の更新</p>
          <ul class="mt-3 space-y-2 text-sm font-bold section-copy">
            {
              recentUpdates.length > 0 ? (
                recentUpdates.map((source) => (
                  <li class="lp-mock-card px-3 py-2">{source.label} {source.count}件</li>
                ))
              ) : (
                <li class="lp-mock-card px-3 py-2">{stats.lastUpdatedLabel}</li>
              )
            }
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>
