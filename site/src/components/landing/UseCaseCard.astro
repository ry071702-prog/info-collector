---
import LandingIcon from "./LandingIcon.astro";

interface Props {
  title: string;
  body: string;
  icon: string;
}

const { title, body, icon } = Astro.props;
---

<article class="lp-card p-5 sm:p-6" data-reveal>
  <div class="mb-5 flex items-center justify-between gap-3">
    <div class="lp-icon">
      <LandingIcon name={icon} />
    </div>
    <span class="status-chip px-3 py-1 text-xs font-bold">活用シーン</span>
  </div>
  <h3 class="lp-title text-lg font-semibold">{title}</h3>
  <p class="lp-copy mt-3 text-sm leading-6">{body}</p>
</article>
