---
import PriorityBadge from "../PriorityBadge.astro";
import { genreLabels, sourceLabel, type Article, type Genre } from "../../lib/articles";

interface Props {
  articles: Record<Genre, Article[]>;
  feedPath: string;
  basePath: string;
}

const { articles, feedPath, basePath } = Astro.props;
const groups: Array<{ genre: Genre; label: string; href: string; accent: string }> = [
  { genre: "games", label: genreLabels.games, href: `${basePath}/games/`, accent: "var(--color-games-start)" },
  { genre: "anime", label: genreLabels.anime, href: `${basePath}/anime/`, accent: "var(--color-anime-start)" },
  { genre: "disney", label: genreLabels.disney, href: `${basePath}/disney/`, accent: "var(--color-disney-start)" },
];
const dateFormatter = new Intl.DateTimeFormat("ja-JP", {
  timeZone: "Asia/Tokyo",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<section class="lp-muted-band px-4 py-20 sm:px-6 lg:px-8" aria-labelledby="latest-news-title">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between" data-reveal>
      <div class="max-w-3xl">
        <p class="lp-eyebrow">Latest News</p>
        <h2 id="latest-news-title" class="lp-title mt-4 text-3xl font-bold sm:text-4xl">最新ニュース（自動収集）</h2>
        <p class="lp-copy mt-4 text-base leading-7">
          AIが収集・要約した実データから、ジャンルごとの新着を表示しています。
        </p>
      </div>
      <a href={feedPath} class="lp-button lp-secondary inline-flex items-center justify-center px-5 py-3 text-sm font-black">
        もっと見る
      </a>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        groups.map((group) => (
          <section class="surface-panel overflow-hidden p-4 sm:p-5" style={`--genre-accent: ${group.accent};`} data-reveal>
            <div class="mb-4 flex items-center justify-between gap-3 border-b border-[var(--border-color)] pb-4">
              <a href={group.href} class="inline-flex items-center gap-2 text-lg font-semibold text-[var(--text-primary)] hover:text-[var(--brand-blue)]">
                <span class="h-3 w-3 rounded-full bg-[var(--genre-accent)]"></span>
                {group.label}
              </a>
              <span class="text-xs font-bold section-kicker">最新 {articles[group.genre].length} 件</span>
            </div>
            <div class="space-y-3">
              {
                articles[group.genre].length > 0 ? (
                  articles[group.genre].map((article) => {
                    const tags = [...article.entity_tags, ...article.title_tags].filter(Boolean).slice(0, 3);
                    return (
                      <article class="soft-card p-4 transition hover:border-[var(--brand-blue)] hover:bg-[var(--surface)]">
                        <div class="mb-3 flex flex-wrap items-center gap-2">
                          <PriorityBadge priority={article.final_priority} />
                          <span class="min-w-0 truncate text-xs font-bold section-kicker">{sourceLabel(article)}</span>
                          <time class="ml-auto shrink-0 text-xs font-bold section-kicker" datetime={article.timestamp}>
                            {dateFormatter.format(new Date(article.timestamp))}
                          </time>
                        </div>
                        <a href={article.url} target="_blank" rel="noreferrer" class="group block">
                          <h3 class="line-clamp-2 text-base font-semibold leading-6 text-[var(--text-primary)] group-hover:text-[var(--brand-blue)]">
                            {article.category_name}
                          </h3>
                          <p class="mt-2 line-clamp-3 text-sm leading-6 section-copy">
                            {article.summary || "概要はまだありません。"}
                          </p>
                        </a>
                        {tags.length > 0 && (
                          <div class="mt-3 flex flex-wrap gap-1.5">
                            {tags.map((tag) => (
                              <span class="status-chip px-2.5 py-1 text-xs font-bold">#{tag}</span>
                            ))}
                          </div>
                        )}
                      </article>
                    );
                  })
                ) : (
                  <p class="empty-state p-5 text-sm">表示できるニュースはまだありません。</p>
                )
              }
            </div>
          </section>
        ))
      }
    </div>
  </div>
</section>
