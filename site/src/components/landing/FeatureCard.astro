---
import LandingIcon from "./LandingIcon.astro";

interface Props {
  title: string;
  body: string;
  icon: string;
}

const { title, body, icon } = Astro.props;
---

<article class="lp-card p-5" data-reveal>
  <div class="lp-icon mb-4">
    <LandingIcon name={icon} />
  </div>
  <h3 class="lp-title text-base font-semibold">{title}</h3>
  <p class="lp-copy mt-2 text-sm leading-6">{body}</p>
</article>
