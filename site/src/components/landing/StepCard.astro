---
import LandingIcon from "./LandingIcon.astro";

interface Props {
  step: string;
  title: string;
  body: string;
  icon: string;
}

const { step, title, body, icon } = Astro.props;
---

<article class="lp-card p-5 sm:p-6" data-reveal>
  <div class="mb-5 flex items-center gap-3">
    <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-950 text-sm font-black text-white">{step}</span>
    <div class="lp-icon">
      <LandingIcon name={icon} />
    </div>
  </div>
  <h3 class="text-lg font-bold text-slate-950">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{body}</p>
</article>
