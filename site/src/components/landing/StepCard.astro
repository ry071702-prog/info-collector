---
import LandingIcon from "./LandingIcon.astro";

interface Props {
  step: string;
  title: string;
  body: string;
  icon: string;
}

const { step, title, body, icon } = Astro.props;
---

<article class="lp-card p-5 sm:p-6" data-reveal>
  <div class="mb-5 flex items-center gap-3">
    <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[var(--brand-blue)] text-sm font-bold text-white">{step}</span>
    <div class="lp-icon">
      <LandingIcon name={icon} />
    </div>
  </div>
  <h3 class="lp-title text-lg font-semibold">{title}</h3>
  <p class="lp-copy mt-3 text-sm leading-6">{body}</p>
</article>
