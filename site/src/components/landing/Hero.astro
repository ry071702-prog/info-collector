---
import { genreLabels, type Article } from "../../lib/articles";

interface Props {
  feedPath: string;
  articles?: Article[];
  todayCount?: number;
  weekCount?: number;
}

const { feedPath, articles = [], todayCount = 0, weekCount = 0 } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("ja-JP", {
  timeZone: "Asia/Tokyo",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
const toneByGenre = {
  games: "var(--color-games-start)",
  anime: "var(--color-anime-start)",
  disney: "var(--color-disney-start)",
};
const badgeByPriority = {
  S: "bg-rose-100 text-rose-700 dark:bg-rose-950 dark:text-rose-300",
  A: "bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300",
  B: "bg-[var(--surface-subtle)] text-[var(--text-primary)] dark:bg-slate-800 dark:text-slate-200",
  C: "bg-[var(--surface-subtle)] text-[var(--text-secondary)] dark:bg-slate-800 dark:text-slate-300",
};
const fallbackExamples = [
  {
    source: "RSS",
    category: "ゲーム",
    priority: "A",
    title: "人気タイトルの大型アップデートが配信開始",
    summary: "新マップとランクシステムを追加。競技シーンへの影響と注目ポイントを整理しました。",
    tags: ["FPS", "アップデート", "eスポーツ"],
    date: "2026/06/05",
    tone: "var(--color-games-start)",
    badge: "bg-orange-100 text-orange-700",
  },
  {
    source: "X",
    category: "アニメ",
    priority: "S",
    title: "話題の新作アニメ、2クール目制作決定",
    summary: "公式が続編を発表。放送時期と原作の到達点、SNSの反応をまとめました。",
    tags: ["新作", "続編", "SNS反応"],
    date: "2026/06/05",
    tone: "var(--color-anime-start)",
    badge: "bg-rose-100 text-rose-700",
  },
  {
    source: "YT",
    category: "Disney",
    priority: "B",
    title: "パークの新アトラクション情報が公開",
    summary: "導入時期と体験内容の概要。来園計画に役立つポイントを抜粋。",
    tags: ["パーク", "新施設"],
    date: "2026/06/05",
    tone: "var(--color-disney-start)",
    badge: "bg-[var(--surface-subtle)] text-[var(--text-primary)]",
  },
];
const examples =
  articles.length > 0
    ? articles.slice(0, 3).map((article) => ({
        source: (article.source_platform || article.domain || "RSS").slice(0, 3).toUpperCase(),
        category: genreLabels[article.genre],
        priority: article.final_priority,
        title: article.category_name || article.title_tags[0] || "最新トピック",
        summary: article.summary || "概要はまだありません。",
        tags: [...article.entity_tags, ...article.title_tags].filter(Boolean).slice(0, 3),
        date: dateFormatter.format(new Date(article.timestamp)),
        tone: toneByGenre[article.genre],
        badge: badgeByPriority[article.final_priority],
      }))
    : fallbackExamples;
---

<section class="px-4 pb-20 pt-16 sm:px-6 sm:pt-24 lg:px-8 lg:pb-28">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-4xl text-center" data-reveal>
      <p class="lp-eyebrow">集めた情報を、使える知識に。</p>
      <h1 class="lp-hero-title mx-auto mt-5 max-w-4xl">
        追いかけなくても、最新情報は集まる。
      </h1>
      <p class="lp-copy mx-auto mt-6 max-w-2xl text-base leading-8 sm:text-xl">
        X・YouTube・Twitch・RSS から、ゲーム/アニメ/Disney の話題を AI が24時間自動で収集・要約・分類。重要なものだけが、毎日この一画面に届きます。
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={feedPath} class="lp-button lp-primary inline-flex items-center justify-center px-6 py-3 text-sm font-bold">
          今日のフィードを見る
        </a>
        <a href="#how" class="lp-button lp-secondary inline-flex items-center justify-center px-6 py-3 text-sm font-bold">
          使い方を見る
        </a>
      </div>
      <div class="lp-copy mx-auto mt-8 grid max-w-2xl gap-3 text-sm sm:grid-cols-3">
        <div class="lp-stat p-4">
          <span class="lp-title block text-2xl font-semibold">{todayCount}</span>
          今日の新着
        </div>
        <div class="lp-stat p-4">
          <span class="lp-title block text-2xl font-semibold">{weekCount}</span>
          今週の新着
        </div>
        <div class="lp-stat p-4">AI要約で、読む前に要点が分かる。</div>
      </div>
    </div>

    <div class="relative mx-auto mt-12 max-w-5xl" data-reveal>
      <div class="lp-floating lp-mock p-4 sm:p-5">
        <div class="mb-4 flex items-center justify-between gap-3 rounded-[1.25rem] bg-[var(--surface-subtle)] px-4 py-3">
          <div>
            <p class="text-xs font-bold text-[var(--brand-blue)]">Today Feed</p>
            <p class="text-sm font-semibold text-[var(--text-primary)]">重要ニュースを自動整理</p>
          </div>
          <span class="rounded-full bg-[var(--brand-blue)] px-3 py-1 text-xs font-bold text-white">LIVE</span>
        </div>
        <div class="grid gap-3 lg:grid-cols-3">
          {
            examples.map((item) => (
              <article class="lp-mock-card p-4">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span
                    class="inline-flex h-8 min-w-8 items-center justify-center rounded-full border px-2 text-xs font-bold"
                    style={`border-color: color-mix(in srgb, ${item.tone} 32%, var(--border-color)); background: color-mix(in srgb, ${item.tone} 8%, var(--surface)); color: ${item.tone};`}
                    aria-label={`収集元 ${item.source}`}
                  >
                    {item.source}
                  </span>
                  <span class="status-chip px-3 py-1 text-xs font-bold">{item.category}</span>
                  <span class={`rounded-full px-3 py-1 text-xs font-bold ${item.badge}`}>重要度{item.priority}</span>
                  <time class="ml-auto text-xs font-bold text-[var(--text-muted)]">{item.date}</time>
                </div>
                <h3 class="lp-title text-base font-semibold leading-6">{item.title}</h3>
                <p class="lp-copy mt-2 line-clamp-3 text-sm leading-6">{item.summary}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="status-chip px-2.5 py-1 text-xs font-bold">#{tag}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
