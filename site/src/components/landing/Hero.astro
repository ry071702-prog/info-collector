---
interface Props {
  feedPath: string;
}

const { feedPath } = Astro.props;
const examples = [
  {
    source: "RSS",
    category: "ゲーム",
    priority: "A",
    title: "人気タイトルの大型アップデートが配信開始",
    summary: "新マップとランクシステムを追加。競技シーンへの影響と注目ポイントを整理しました。",
    tags: ["FPS", "アップデート", "eスポーツ"],
    date: "2026/06/05",
    tone: "from-blue-600 to-cyan-500",
    badge: "bg-orange-100 text-orange-700",
  },
  {
    source: "X",
    category: "アニメ",
    priority: "S",
    title: "話題の新作アニメ、2クール目制作決定",
    summary: "公式が続編を発表。放送時期と原作の到達点、SNSの反応をまとめました。",
    tags: ["新作", "続編", "SNS反応"],
    date: "2026/06/05",
    tone: "from-violet-500 to-pink-500",
    badge: "bg-rose-100 text-rose-700",
  },
  {
    source: "YT",
    category: "Disney",
    priority: "B",
    title: "パークの新アトラクション情報が公開",
    summary: "導入時期と体験内容の概要。来園計画に役立つポイントを抜粋。",
    tags: ["パーク", "新施設"],
    date: "2026/06/05",
    tone: "from-amber-500 to-yellow-400",
    badge: "bg-slate-100 text-slate-700",
  },
];
---

<section class="px-4 pb-20 pt-14 sm:px-6 sm:pt-20 lg:px-8 lg:pb-24">
  <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
    <div data-reveal>
      <p class="text-sm font-black uppercase text-blue-700">集めた情報を、使える知識に。</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-black leading-tight text-slate-950 sm:text-5xl lg:text-6xl">
        追いかけなくても、最新情報は集まる。
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
        X・YouTube・Twitch・RSS から、ゲーム/アニメ/Disney の話題を AI が24時間自動で収集・要約・分類。重要なものだけが、毎日この一画面に届きます。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href={feedPath} class="lp-button lp-primary inline-flex items-center justify-center px-6 py-3 text-sm font-black">
          今日のフィードを見る
        </a>
        <a href="#how" class="lp-button lp-secondary inline-flex items-center justify-center px-6 py-3 text-sm font-black">
          使い方を見る
        </a>
      </div>
      <div class="mt-8 grid max-w-xl gap-3 text-sm text-slate-600 sm:grid-cols-3">
        <div class="rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200">AI要約で、読む前に要点が分かる。</div>
        <div class="rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200">タグとカテゴリで、情報が迷子にならない。</div>
        <div class="rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200">ライブ更新と PWA で毎日確認しやすい。</div>
      </div>
    </div>

    <div class="relative" data-reveal>
      <div class="lp-floating rounded-[2rem] border border-white bg-white/88 p-4 shadow-[0_24px_70px_rgba(15,23,42,0.14)] ring-1 ring-slate-200 backdrop-blur">
        <div class="mb-4 flex items-center justify-between gap-3 rounded-2xl bg-slate-950 px-4 py-3 text-white">
          <div>
            <p class="text-xs font-bold text-cyan-200">Today Feed</p>
            <p class="text-sm font-black">重要ニュースを自動整理</p>
          </div>
          <span class="rounded-full bg-cyan-400 px-3 py-1 text-xs font-black text-slate-950">LIVE</span>
        </div>
        <div class="space-y-3">
          {
            examples.map((item) => (
              <article class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class={`inline-flex h-8 min-w-8 items-center justify-center rounded-xl bg-gradient-to-br ${item.tone} px-2 text-xs font-black text-white`} aria-label={`収集元 ${item.source}`}>
                    {item.source}
                  </span>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-700">{item.category}</span>
                  <span class={`rounded-full px-3 py-1 text-xs font-black ${item.badge}`}>重要度{item.priority}</span>
                  <time class="ml-auto text-xs font-bold text-slate-400">{item.date}</time>
                </div>
                <h3 class="text-base font-black leading-6 text-slate-950">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{item.summary}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full bg-slate-50 px-2.5 py-1 text-xs font-bold text-slate-500">#{tag}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
