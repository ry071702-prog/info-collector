---
interface Props {
  showRange?: boolean;
}

const { showRange = false } = Astro.props;
---

<div class="glass-panel mb-6 flex flex-col gap-3 p-3" data-article-controls data-show-range={String(showRange)}>
  <div class="flex flex-wrap items-center gap-3">
    <label class="flex items-center gap-2">
      <span class="text-sm font-bold section-kicker">並び順</span>
      <select class="article-control-field h-10 pr-8" data-sort-select>
        <option value="new">新着順</option>
        <option value="importance">重要度順</option>
      </select>
    </label>
    <label class="flex items-center gap-2">
      <span class="text-sm font-bold section-kicker">期間</span>
      <select class="article-control-field h-10 pr-8" data-period-select>
        <option value="all">全期間</option>
        <option value="24h">過去24h</option>
        <option value="7d">7d</option>
        <option value="30d">30d</option>
      </select>
    </label>
    <details class="relative" data-tag-filter>
      <summary class="article-control-field flex h-10 cursor-pointer list-none items-center gap-2">
        タグ
        <span class="glass-chip px-1.5 py-0.5 text-xs" data-tag-count>0</span>
      </summary>
      <div class="article-filter-panel max-h-80 overflow-y-auto" data-tag-options></div>
    </details>
    <details class="relative" data-source-filter>
      <summary class="article-control-field flex h-10 cursor-pointer list-none items-center gap-2">
        Source
        <span class="glass-chip px-1.5 py-0.5 text-xs" data-source-count>0</span>
      </summary>
      <div class="article-filter-panel" data-source-options></div>
    </details>
    <button
      type="button"
      class="glass-control px-3 text-sm font-bold"
      data-clear-filters
    >
      フィルタクリア
    </button>
  </div>
  <label class="flex min-w-0 items-center gap-2 sm:max-w-xl">
    <span class="sr-only">記事検索</span>
    <input
      type="search"
      class="article-control-field min-w-48 flex-1"
      placeholder="タイトル・要約・タグで検索..."
      autocomplete="off"
      data-search-input
    />
    <span class="shrink-0 text-sm tabular-nums section-kicker" data-search-count>0 件</span>
  </label>
</div>
