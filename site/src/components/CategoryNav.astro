---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathWithBase = (path: string) => `${base}${path}`;
const links = [
  { href: pathWithBase("/feed/"), label: "最新フィード" },
  { href: pathWithBase("/games/"), label: "ゲーム" },
  { href: pathWithBase("/anime/"), label: "アニメ" },
  { href: pathWithBase("/disney/"), label: "Disney" },
  { href: pathWithBase("/dashboard/"), label: "ダッシュボード" },
  { href: pathWithBase("/collection/"), label: "コレクション" },
  { href: pathWithBase("/trends/"), label: "トレンド" },
  { href: pathWithBase("/tags/"), label: "タグ" },
  { href: pathWithBase("/favorites/"), label: "お気に入り" },
  { href: pathWithBase("/newspaper/"), label: "新聞" },
];

const normalize = (value: string) => (value.endsWith("/") ? value : `${value}/`);
---

<nav class="surface-panel flex gap-1.5 overflow-x-auto rounded-full p-1.5 shadow-none" aria-label="カテゴリ">
  {
    links.map((link) => {
      const active = normalize(currentPath) === normalize(link.href);
      return (
        <a
          href={link.href}
          aria-current={active ? "page" : undefined}
          class:list={[
            "whitespace-nowrap rounded-full border border-transparent px-3.5 py-2 text-sm font-medium transition",
            active && "nav-active",
            !active && "text-[var(--text-secondary)] hover:bg-[var(--surface-subtle)] hover:text-[var(--text-primary)]",
          ]}
        >
          {link.label}
        </a>
      );
    })
  }
</nav>

<style>
  .nav-active {
    border-color: transparent;
    background: var(--brand-blue);
    color: #ffffff;
  }
</style>
