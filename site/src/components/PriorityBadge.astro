---
import type { Priority } from "../lib/articles";

interface Props {
  priority: Priority;
}

const { priority } = Astro.props;
const styles: Record<Priority, string> = {
  S: "background: #fff1f2; border-color: #fecdd3; color: #be123c;",
  A: "background: #fff7ed; border-color: #fed7aa; color: #c2410c;",
  B: "background: var(--surface-subtle); border-color: var(--border-color); color: var(--text-secondary);",
  C: "background: var(--surface-subtle); border-color: var(--border-color); color: var(--text-muted);",
};
---

<span
  class="inline-flex min-w-8 items-center justify-center rounded-full border px-2.5 py-1 text-xs font-bold"
  style={styles[priority] ?? styles.C}
>
  {priority}
</span>
