---
import PriorityBadge from "./PriorityBadge.astro";
import { genreLabels, sourceKey, sourceLabel, type Article, type Genre } from "../lib/articles";
import { hasTagPage, tagPathSegment } from "../lib/stats";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const allTags = Array.from(new Set([...article.entity_tags, ...article.title_tags].filter(Boolean)));
const relativeFormatter = new Intl.RelativeTimeFormat("ja", { numeric: "auto" });
const timestamp = new Date(article.timestamp);
const diffHours = Math.round((timestamp.getTime() - Date.now()) / 3_600_000);
const relativeTime =
  Number.isNaN(timestamp.getTime())
    ? ""
    : Math.abs(diffHours) < 24
      ? relativeFormatter.format(diffHours, "hour")
      : relativeFormatter.format(Math.round(diffHours / 24), "day");
const searchBlob = [
  article.category_name,
  ...article.entity_tags,
  ...article.title_tags,
  article.summary,
  article.author,
]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entities = article.entity_tags.slice(0, 3).map((tag) => ({
  tag,
  href: hasTagPage(tag) ? `${base}/tags/${tagPathSegment(tag)}/` : null,
}));
const imageSrc = article.image_url ? `${base}${article.image_url}` : null;
const isUrgent = article.final_priority === "S" || article.final_priority === "A";
const source = { key: sourceKey(article), label: sourceLabel(article) };
const articleId = article.url;
const genreAccent: Record<Genre, { start: string; end: string; border: string }> = {
  games: {
    start: "var(--color-games-start)",
    end: "var(--color-games-end)",
    border: "color-mix(in srgb, var(--color-games-start) 38%, var(--border-color))",
  },
  anime: {
    start: "var(--color-anime-start)",
    end: "var(--color-anime-end)",
    border: "color-mix(in srgb, var(--color-anime-start) 34%, var(--border-color))",
  },
  disney: {
    start: "var(--color-disney-start)",
    end: "var(--color-disney-end)",
    border: "color-mix(in srgb, var(--color-disney-start) 38%, var(--border-color))",
  },
};
const accent = genreAccent[article.genre];
const cardStyle = `--card-accent: ${accent.start}; --card-accent-end: ${accent.end}; --card-border-hover: ${accent.border};`;
const genreBadgeStyle = `border-color: color-mix(in srgb, ${accent.start} 32%, var(--border-color)); background: color-mix(in srgb, ${accent.start} 8%, var(--surface)); color: ${accent.start};`;
const fallbackStyle = `background: linear-gradient(180deg, color-mix(in srgb, ${accent.start} 9%, var(--surface-subtle)), var(--surface-subtle)); color: ${accent.start};`;
---

<article
  data-article-card
  data-article-id={articleId}
  data-timestamp={article.timestamp}
  data-priority={article.final_priority}
  data-search-blob={searchBlob}
  data-tags={JSON.stringify(allTags)}
  data-source={source.key}
  data-source-label={source.label}
  tabindex="-1"
  style={cardStyle}
  class="surface-card group relative flex h-full flex-col overflow-hidden transition-opacity"
>
  <span
    class="pointer-events-none absolute left-3 top-3 z-10 hidden rounded-full bg-[var(--surface-inverse)] px-2.5 py-1 text-xs font-bold text-[var(--page-bg)] shadow-sm"
    data-read-label
  >
    既読
  </span>
  <div class="absolute right-3 top-3 z-20 flex items-center gap-1.5">
    <button
      type="button"
      class="icon-button h-9 w-9 text-base leading-none hover:text-rose-500"
      data-hide-toggle
      aria-label="この記事を不要として隠す"
      aria-pressed="false"
      title="不要としてマーク"
    >
      ×
    </button>
    <button
      type="button"
      class="icon-button h-9 w-9 text-lg leading-none hover:text-[var(--card-accent)]"
      data-favorite-toggle
      aria-label="お気に入りに追加"
      aria-pressed="false"
    >
      ☆
    </button>
  </div>
  <div class="aspect-[4/3] overflow-hidden bg-[var(--surface-subtle)]">
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="block h-full">
      {
        imageSrc ? (
          <img
            src={imageSrc}
            alt=""
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.035]"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full w-full flex-col items-center justify-center gap-2" style={fallbackStyle}>
            {article.favicon_url && (
              <img
                src={article.favicon_url}
                alt=""
                class="h-12 w-12 rounded-2xl bg-white/90 p-1.5 shadow"
                loading="lazy"
              />
            )}
            <span class="text-sm font-semibold">{genreLabels[article.genre]}</span>
            {article.domain && (
              <span class="text-xs text-[var(--text-secondary)]">{article.domain}</span>
            )}
          </div>
        )
      }
    </a>
  </div>
  <div class="flex flex-1 flex-col gap-3 border-t border-[var(--border-color)] bg-[var(--surface)] p-4">
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="contents">
      <div class="flex flex-wrap items-center gap-2">
        <PriorityBadge priority={article.final_priority} />
        <span class="rounded-full border px-2.5 py-1 text-xs font-bold" style={genreBadgeStyle}>
          {genreLabels[article.genre]}
        </span>
        {
          article.flags.speed === "速報" && (
            <span class="rounded-full bg-[var(--brand-blue)] px-2.5 py-1 text-xs font-bold text-white shadow-sm">速報</span>
          )
        }
        {
          article.flags.spoiler !== "なし" && (
            <span class="rounded-full bg-[var(--surface-inverse)] px-2.5 py-1 text-xs font-bold text-[var(--page-bg)] shadow-sm">ネタバレ注意</span>
          )
        }
      </div>
      <h3 class="news-card-title text-lg font-black leading-snug">
        {article.category_name}
      </h3>
      <p class="line-clamp-2 text-sm leading-6 section-copy">
        {article.summary || "概要はまだありません。"}
      </p>
    </a>
    {
      entities.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {entities.map((item) =>
            item.href ? (
              <a href={item.href} class="entity-tag rounded-full px-2.5 py-1 text-xs font-medium">
                {item.tag}
              </a>
            ) : (
              <span class="entity-tag rounded-full px-2.5 py-1 text-xs font-medium">
                {item.tag}
              </span>
            ),
          )}
        </div>
      )
    }
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="mt-auto block">
      <div class="flex items-center justify-between gap-3 border-t border-[var(--border-color)] pt-3 text-xs section-kicker">
        <span class="min-w-0 truncate">{article.author || "unknown"}</span>
        <time
          datetime={article.timestamp}
          class:list={[
            "shrink-0",
            isUrgent && "font-bold text-rose-600 dark:text-rose-300",
          ]}
        >
          {relativeTime}
        </time>
      </div>
    </a>
  </div>
</article>
