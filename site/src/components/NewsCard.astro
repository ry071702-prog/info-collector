---
import PriorityBadge from "./PriorityBadge.astro";
import { genreColors, genreLabels, sourceKey, sourceLabel, type Article } from "../lib/articles";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const allTags = Array.from(new Set([...article.entity_tags, ...article.title_tags].filter(Boolean)));
const relativeFormatter = new Intl.RelativeTimeFormat("ja", { numeric: "auto" });
const timestamp = new Date(article.timestamp);
const diffHours = Math.round((timestamp.getTime() - Date.now()) / 3_600_000);
const relativeTime =
  Number.isNaN(timestamp.getTime())
    ? ""
    : Math.abs(diffHours) < 24
      ? relativeFormatter.format(diffHours, "hour")
      : relativeFormatter.format(Math.round(diffHours / 24), "day");
const entities = article.entity_tags.slice(0, 3);
const searchBlob = [
  article.category_name,
  ...article.entity_tags,
  ...article.title_tags,
  article.summary,
  article.author,
]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();
const fallbackStyle = `background: linear-gradient(135deg, ${genreColors[article.genre]}, #0f172a);`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const imageSrc = article.image_url ? `${base}${article.image_url}` : null;
const isUrgent = article.final_priority === "S" || article.final_priority === "A";
const source = { key: sourceKey(article), label: sourceLabel(article) };
const articleId = article.url;
---

<article
  data-article-card
  data-article-id={articleId}
  data-timestamp={article.timestamp}
  data-priority={article.final_priority}
  data-search-blob={searchBlob}
  data-tags={JSON.stringify(allTags)}
  data-source={source.key}
  data-source-label={source.label}
  tabindex="-1"
  class="group relative flex h-full flex-col overflow-hidden rounded-sm border border-stone-300 bg-[var(--paper)] shadow-sm transition-opacity hover:border-stone-500 hover:shadow-md dark:border-stone-700 dark:bg-stone-900 dark:hover:border-stone-500"
>
  <span
    class="pointer-events-none absolute left-2 top-2 z-10 hidden rounded-sm bg-stone-950/85 px-2 py-1 text-xs font-bold text-white shadow-sm dark:bg-white/90 dark:text-stone-950"
    data-read-label
  >
    既読
  </span>
  <div class="absolute right-2 top-2 z-20 flex items-center gap-1.5">
    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded-sm border border-stone-100/80 bg-[var(--paper)]/95 text-lg leading-none text-stone-500 shadow-sm hover:bg-white hover:text-rose-600 focus:outline-none focus:ring-2 focus:ring-stone-300 dark:border-stone-700/80 dark:bg-stone-950/90 dark:text-stone-400 dark:hover:bg-stone-900 dark:hover:text-rose-400"
      data-hide-toggle
      aria-label="この記事を不要として隠す"
      aria-pressed="false"
      title="不要としてマーク"
    >
      🚫
    </button>
    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded-sm border border-stone-100/80 bg-[var(--paper)]/95 text-lg leading-none text-stone-500 shadow-sm hover:bg-white hover:text-[#1e3a5f] focus:outline-none focus:ring-2 focus:ring-stone-300 dark:border-stone-700/80 dark:bg-stone-950/90 dark:text-stone-400 dark:hover:bg-stone-900 dark:hover:text-stone-100"
      data-favorite-toggle
      aria-label="お気に入りに追加"
      aria-pressed="false"
    >
      ☆
    </button>
  </div>
  <div class="aspect-[4/3] overflow-hidden bg-stone-200 dark:bg-stone-800">
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="block h-full">
      {
        imageSrc ? (
          <img
            src={imageSrc}
            alt=""
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full w-full flex-col items-center justify-center gap-2" style={fallbackStyle}>
            {article.favicon_url && (
              <img
                src={article.favicon_url}
                alt=""
                class="h-12 w-12 rounded bg-white/90 p-1.5 shadow"
                loading="lazy"
              />
            )}
            <span class="text-sm font-semibold text-white/90">{genreLabels[article.genre]}</span>
            {article.domain && (
              <span class="text-xs text-white/70">{article.domain}</span>
            )}
          </div>
        )
      }
    </a>
  </div>
  <div class="flex flex-1 flex-col gap-3 border-t border-stone-300 p-4 dark:border-stone-700">
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="contents">
      <div class="flex flex-wrap items-center gap-2">
        <PriorityBadge priority={article.final_priority} />
          <span class="rounded-sm bg-stone-200 px-2 py-1 text-xs font-medium text-stone-700 dark:bg-stone-800 dark:text-stone-300">
          {genreLabels[article.genre]}
        </span>
        {
          article.flags.speed === "速報" && (
            <span class="rounded-sm bg-[#1e3a5f] px-2 py-1 text-xs font-bold text-white">速報</span>
          )
        }
        {
          article.flags.spoiler !== "なし" && (
            <span class="rounded-sm bg-stone-900 px-2 py-1 text-xs font-bold text-white dark:bg-stone-100 dark:text-stone-950">ネタバレ注意</span>
          )
        }
      </div>
      <h3 class="font-serif-jp text-lg font-black leading-snug text-stone-950 group-hover:text-[#1e3a5f] dark:text-white dark:group-hover:text-stone-200">
        {article.category_name}
      </h3>
      <p class="line-clamp-2 text-sm leading-6 text-stone-600 dark:text-stone-300">
        {article.summary || "概要はまだありません。"}
      </p>
    </a>
    {
      entities.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {entities.map((tag) => (
            <button
              type="button"
              class="rounded-sm bg-stone-200 px-2 py-1 text-xs text-stone-600 hover:bg-stone-300 hover:text-stone-950 focus:outline-none focus:ring-2 focus:ring-stone-400 dark:bg-stone-800 dark:text-stone-400 dark:hover:bg-stone-700 dark:hover:text-white"
              data-search-tag={tag}
            >
              {tag}
            </button>
          ))}
        </div>
      )
    }
    <a href={article.url} target="_blank" rel="noreferrer" data-article-link class="mt-auto block">
      <div class="flex items-center justify-between gap-3 border-t border-stone-200 pt-3 text-xs text-stone-500 dark:border-stone-800 dark:text-stone-400">
        <span class="min-w-0 truncate">{article.author || "unknown"}</span>
        <time
          datetime={article.timestamp}
          class:list={[
            "shrink-0",
            isUrgent && "font-bold text-[#1e3a5f] dark:text-stone-200",
          ]}
        >
          {relativeTime}
        </time>
      </div>
    </a>
  </div>
</article>
