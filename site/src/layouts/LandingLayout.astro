---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "X・YouTube・Twitch・RSS からゲーム/アニメ/Disney の話題を AI が自動収集・要約・分類するニュースリーダー。",
} = Astro.props;
const basePath = import.meta.env.BASE_URL;
const homePath = basePath.endsWith("/") ? basePath : `${basePath}/`;
const feedPath = `${homePath}feed/`;
const collectionPath = `${homePath}collection/`;
const pageTitle = `${title} | info-collector`;
const manifestPath = `${homePath}manifest.json`;
const icon192Path = `${homePath}icon-192.svg`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="application-name" content="info-collector" />
    <meta name="apple-mobile-web-app-title" content="Info" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link rel="manifest" href={manifestPath} />
    <link rel="icon" href={icon192Path} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={icon192Path} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const theme = stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.classList.add("js");
        document.documentElement.classList.toggle("dark", theme === "dark" || (theme === "system" && prefersDark));
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="landing-body">
    <header class="landing-header">
      <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8" aria-label="ランディングページ">
        <a href={homePath} class="landing-logo" aria-label="情報収集 ホーム">
          <span class="landing-logo-mark">情</span>
          <span>情報収集</span>
        </a>
        <button
          type="button"
          class="landing-menu-button md:hidden"
          aria-controls="landing-nav"
          aria-expanded="false"
          data-landing-menu-toggle
        >
          <span class="sr-only">メニューを開閉</span>
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
          </svg>
        </button>
        <div id="landing-nav" class="landing-nav" data-landing-nav>
          <a href={`${homePath}#features`}>機能</a>
          <a href={`${homePath}#how`}>使い方</a>
          <a href={`${homePath}#usecases`}>活用シーン</a>
          <a href={collectionPath}>コレクション</a>
          <button
            type="button"
            class="icon-button"
            data-landing-theme-toggle
            aria-label="テーマを切り替え"
          >
            <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79Z"></path>
            </svg>
          </button>
          <a href={feedPath} class="landing-nav-cta">今日のフィードを見る</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline define:vars={{ basePath }}>
      (() => {
        if (!("serviceWorker" in navigator)) return;
        window.addEventListener("load", () => {
          navigator.serviceWorker.register(`${basePath}sw.js`, { scope: basePath }).catch((error) => {
            console.warn("Service Worker registration failed:", error);
          });
        });
      })();
    </script>
    <script is:inline>
      (() => {
        document.body.classList.add("landing-js");
        const toggle = document.querySelector("[data-landing-menu-toggle]");
        const nav = document.querySelector("[data-landing-nav]");
        const themeToggle = document.querySelector("[data-landing-theme-toggle]");
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const readTheme = () => {
          const value = localStorage.getItem("theme");
          return value === "light" || value === "dark" || value === "system" ? value : "system";
        };
        const applyTheme = (theme) => {
          const isDark = theme === "dark" || (theme === "system" && media.matches);
          document.documentElement.classList.toggle("dark", isDark);
          document.documentElement.dataset.theme = theme;
          localStorage.setItem("theme", theme);
        };
        toggle?.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!expanded));
          nav?.classList.toggle("is-open", !expanded);
        });
        themeToggle?.addEventListener("click", () => {
          applyTheme(document.documentElement.classList.contains("dark") ? "light" : "dark");
        });
        media.addEventListener("change", () => {
          if (readTheme() === "system") applyTheme("system");
        });

        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const targets = Array.from(document.querySelectorAll("[data-reveal]"));
        if (reduced || !("IntersectionObserver" in window)) {
          targets.forEach((target) => target.classList.add("is-visible"));
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.12 },
        );
        targets.forEach((target) => observer.observe(target));
      })();
    </script>
  </body>
</html>
