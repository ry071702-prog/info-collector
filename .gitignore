# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/

# Environment
.env
.env.local
*.local

# Secrets (only example committed)
config/secrets/*
!config/secrets/.gitkeep

# Generated data: collect → commit → process フロー上、raw/cache/logs は git で受け渡しする
# 容量が膨らんだら maintenance_monthly で古い分を整理する想定
# data/raw/
# data/cache/
# data/logs/

# Keep processed data committed (it's the archive)
!data/processed/

# IDE
.vscode/
.idea/
.DS_Store
.claude/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Static news site
site/node_modules/
site/dist/
site/.astro/
site/src/data/articles.json
site/public/articles.json
site/public/og-cache/
