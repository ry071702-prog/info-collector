# ============================================================
# Required - Google Gemini API（無料枠で運用可能）
# ============================================================
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=AIzaSy...
# 任意: 無料枠を複数キーで fail-over する場合に設定
GEMINI_API_KEY_2=

# ============================================================
# X (Twitter) - twscrape
# ============================================================
# JSON配列形式。cookies を入れると cookie ログイン (ct0 を含むと即 active 化し、
# username/password の自動ログインフロー=データセンターIPで403の発生源 を回避)。
# 推奨運用: ローカル Mac (居住者IP, launchd) で X だけ収集し data/raw を push。
#   scripts/run_x_local.sh + com.infocollector.xcollect.plist 参照。
#
# cookie 方式 (推奨。password/email/email_password は空文字でよい):
#   [{"username":"sub_acct","email":"","password":"","email_password":"","cookies":"auth_token=XXX; ct0=YYY"}]
# 従来の id/pass 方式 (居住者IP なら可。Actions=データセンターIPは403):
#   [{"username":"...","password":"...","email":"...","email_password":"..."}]
# cookie 取得: x.com にサブ垢ログイン→DevTools→Application→Cookies→https://x.com
#   の auth_token (HttpOnly) と ct0 をコピー。auth_token はパスワード相当=commit禁止。
X_ACCOUNTS=[]

# このマシンで回す collector を限定 (カンマ区切り)。ローカルX専用実行で使う。
# 例: COLLECTORS=x,x_search  /  未設定なら全 collector (Actions はこれ)。
COLLECTORS=

# ============================================================
# YouTube
# ============================================================
# RSS（チャンネル登録動画取得）のみなら不要。
# platform=YouTubeSearch / YouTubeTrending を使う場合に必要。
# 取得: https://console.cloud.google.com/apis/credentials
# 無料枠: 10,000 quota units/日（search.list=100/回, mostPopular=1/回）
YOUTUBE_API_KEY=

# ============================================================
# Twitch
# ============================================================
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ============================================================
# Google Sheets (watchlist管理 + 出力)
# ============================================================
# サービスアカウントJSONの中身をそのまま貼る（一行化推奨）
GOOGLE_SHEETS_CREDENTIALS={}
GOOGLE_SHEETS_ID=

# ============================================================
# Notion
# ============================================================
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID_GAMES=
NOTION_DATABASE_ID_ANIME=
NOTION_DATABASE_ID_DISNEY=

# ============================================================
# Discord
# ============================================================
DISCORD_WEBHOOK_PRIORITY=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_OPS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/...

# ============================================================
# Operational
# ============================================================
DRY_RUN=false
LOG_LEVEL=INFO
