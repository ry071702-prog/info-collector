# ============================================================
# Required - Google Gemini API（無料枠で運用可能）
# ============================================================
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=AIzaSy...

# ============================================================
# X (Twitter) - twscrape
# ============================================================
# JSON配列形式: [{"username":"...","password":"...","email":"...","email_password":"..."}, ...]
X_ACCOUNTS=[]

# ============================================================
# YouTube
# ============================================================
# RSS のみなら不要。検索機能を使う場合のみ
YOUTUBE_API_KEY=

# ============================================================
# Twitch
# ============================================================
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ============================================================
# Google Sheets (watchlist管理 + 出力)
# ============================================================
# サービスアカウントJSONの中身をそのまま貼る（一行化推奨）
GOOGLE_SHEETS_CREDENTIALS={}
GOOGLE_SHEETS_ID=

# ============================================================
# Notion
# ============================================================
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID_GAMES=
NOTION_DATABASE_ID_ANIME=

# ============================================================
# Discord
# ============================================================
DISCORD_WEBHOOK_PRIORITY=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_OPS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/...

# ============================================================
# Operational
# ============================================================
DRY_RUN=false
LOG_LEVEL=INFO
